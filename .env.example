# Woodchuck Configuration

# HTTP server port
HTTP_PORT=1212

# WebSocket server port (can be same as HTTP or different)
WS_PORT=3001

# Logging level (trace, debug, info, warn, error)
LOG_LEVEL=info

# Directory containing project folders
PROJECTS_DIR=/Users/your-username/projects

# Graceful shutdown timeout in seconds
SHUTDOWN_TIMEOUT_SECS=5

# Static files directory for PWA (relative to cwd or absolute)
STATIC_DIR=app/dist

# ntfy notification server (optional - leave blank to disable)
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=woodchuck-your-topic

# Web Push VAPID keys (optional - leave blank to disable web push)
# Generate with: npx web-push generate-vapid-keys
# Both keys are base64 URL-safe encoded (no padding)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=

# TLS/HTTPS (optional - enables HTTPS for mobile access)
# For Tailscale: tailscale cert your-machine.tailnet-name.ts.net
# Place certs in app/certs/ (gitignored)
TLS_CERT=
TLS_KEY=

# External URL for Woodchuck (used by Claude Code hooks)
# Defaults to http://localhost:{HTTP_PORT}
# Set this if accessing from a different hostname (e.g., via Tailscale)
WOODCHUCK_EXTERNAL_URL=
